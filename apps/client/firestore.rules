rules_version = '2';

// Firebase Auth is now required for all access.
// Google users are authenticated via Firebase Auth (request.auth != null).
// Test users (username-only login) bypass Firebase Auth — they are only
// usable in development; in production all users should have Google sign-in.
// TODO: Add per-family scoping rules as a future improvement.

service cloud.firestore {
  match /databases/{database}/documents {

    // Medicine reference data — public read (needed at app startup before login), auth required to write
    match /medicines/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Operational collections — require Firebase Auth session
    match /kids/{docId} {
      allow read, write: if request.auth != null;
    }

    match /logs/{docId} {
      allow read, write: if request.auth != null;
    }

    match /tasks/{docId} {
      allow read, write: if request.auth != null;
    }

    match /users/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /families/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Registration requests - public write, admin-only read
    match /registration_requests/{docId} {
      // Admin can read all registration requests
      allow read: if request.auth != null && 
                  exists(/databases/$(database)/documents/users/admin) &&
                  get(/databases/$(database)/documents/users/admin).data.email == request.auth.token.email;
      
      // Anyone (unauthenticated) can create a registration request
      allow create: if request.resource.data.keys().hasAll(['username', 'email', 'familyName', 'timestamp', 'status']) &&
                    request.resource.data.status == 'pending' &&
                    request.resource.data.username is string &&
                    request.resource.data.username.size() >= 2 &&
                    request.resource.data.email is string &&
                    request.resource.data.email.matches('.*@.*') &&
                    request.resource.data.familyName is string &&
                    request.resource.data.familyName.size() >= 2 &&
                    request.resource.data.timestamp == request.time;
      
      // Only admin can update registration requests
      allow update: if request.auth != null && 
                    exists(/databases/$(database)/documents/users/admin) &&
                    get(/databases/$(database)/documents/users/admin).data.email == request.auth.token.email;
      
      allow delete: if false;
    }
  }
}